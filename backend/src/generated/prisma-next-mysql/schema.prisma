generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-next-mysql"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SCANNER
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum EventType {
  GALA
  VILLAGE
  RAFFLE
  OTHER
}

enum OrderStatus {
  PENDING
  PAYMENT_PROCESSING
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum TicketStatus {
  GENERATED
  USED
  CANCELLED
}

enum ScanResult {
  SUCCESS
  ALREADY_USED
  INVALID
  CANCELLED_TICKET
  EVENT_MISMATCH
}

enum StockReservationStatus {
  ACTIVE
  CONVERTED
  RELEASED
  EXPIRED
}

enum RaffleTicketStatus {
  ASSIGNED
  CANCELLED
  WINNER
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id            String         @id @default(uuid()) @db.Char(36)
  email         String         @unique @db.VarChar(191)
  phone         String?        @unique @db.VarChar(32)
  passwordHash  String?        @map("password_hash") @db.VarChar(191)
  authProvider  AuthProvider   @default(LOCAL) @map("auth_provider")
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  role          UserRole       @default(CUSTOMER)
  isActive      Boolean        @default(true) @map("is_active")
  lastLoginAt   DateTime?      @map("last_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  orders        Order[]
  scans         TicketScan[]   @relation("ScannerScans")
  auditLogs     AuditLog[]     @relation("AuditActor")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  userAgent String?   @map("user_agent") @db.VarChar(255)
  ipAddress String?   @map("ip_address") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Event {
  id           String       @id @default(uuid()) @db.Char(36)
  name         String       @db.VarChar(150)
  slug         String       @unique @db.VarChar(120)
  type         EventType
  description  String?      @db.Text
  venue        String?      @db.VarChar(191)
  timezone     String       @default("Africa/Abidjan") @db.VarChar(64)
  capacity     Int?
  saleStartsAt DateTime?    @map("sale_starts_at")
  saleEndsAt   DateTime?    @map("sale_ends_at")
  startAt      DateTime     @map("start_at")
  endAt        DateTime?    @map("end_at")
  isActive     Boolean      @default(true) @map("is_active")
  metadata     Json?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  ticketTypes  TicketType[]
  orderItems   OrderItem[]
  tickets      Ticket[]

  @@index([type, isActive])
  @@index([startAt])
  @@map("events")
}

model TicketType {
  id                   String             @id @default(uuid()) @db.Char(36)
  eventId              String             @map("event_id") @db.Char(36)
  name                 String             @db.VarChar(120)
  code                 String             @db.VarChar(64)
  description          String?            @db.Text
  priceAmount          Int                @map("price_amount")
  currency             String             @default("XOF") @db.VarChar(8)
  stockTotal           Int?               @map("stock_total")
  maxPerOrder          Int                @default(10) @map("max_per_order")
  requiresAttendeeInfo Boolean            @default(false) @map("requires_attendee_info")
  isActive             Boolean            @default(true) @map("is_active")
  saleStartsAt         DateTime?          @map("sale_starts_at")
  saleEndsAt           DateTime?          @map("sale_ends_at")
  sortOrder            Int                @default(0) @map("sort_order")
  metadata             Json?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  event                Event              @relation(fields: [eventId], references: [id], onDelete: Restrict)
  orderItems           OrderItem[]
  tickets              Ticket[]
  stockReservations    StockReservation[]

  @@unique([eventId, code])
  @@index([eventId, isActive])
  @@map("ticket_types")
}

model Order {
  id                String                @id @default(uuid()) @db.Char(36)
  reference         String                @unique @db.VarChar(64)
  userId            String?               @map("user_id") @db.Char(36)
  customerFirstName String                @map("customer_first_name") @db.VarChar(100)
  customerLastName  String                @map("customer_last_name") @db.VarChar(100)
  customerEmail     String                @map("customer_email") @db.VarChar(191)
  customerPhone     String?               @map("customer_phone") @db.VarChar(32)
  currency          String                @default("XOF") @db.VarChar(8)
  subtotalAmount    Int                   @map("subtotal_amount")
  feesAmount        Int                   @default(0) @map("fees_amount")
  totalAmount       Int                   @map("total_amount")
  status            OrderStatus           @default(PENDING)
  expiresAt         DateTime              @map("expires_at")
  paidAt            DateTime?             @map("paid_at")
  cancelledAt       DateTime?             @map("cancelled_at")
  failureReason     String?               @map("failure_reason") @db.VarChar(255)
  metadata          Json?
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  user              User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]
  tickets           Ticket[]
  stockReservations StockReservation[]
  raffleTickets     RaffleTicket[]
  notifications     Notification[]
  webhookEvents     PaymentWebhookEvent[]

  @@index([userId])
  @@index([status, expiresAt])
  @@index([customerEmail])
  @@map("orders")
}

model OrderItem {
  id             String     @id @default(uuid()) @db.Char(36)
  orderId        String     @map("order_id") @db.Char(36)
  eventId        String     @map("event_id") @db.Char(36)
  ticketTypeId   String     @map("ticket_type_id") @db.Char(36)
  label          String     @db.VarChar(191)
  quantity       Int
  unitAmount     Int        @map("unit_amount")
  subtotalAmount Int        @map("subtotal_amount")
  metadata       Json?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event          Event      @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticketType     TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  tickets        Ticket[]

  @@index([orderId])
  @@index([eventId, ticketTypeId])
  @@map("order_items")
}

model StockReservation {
  id           String                 @id @default(uuid()) @db.Char(36)
  orderId      String                 @map("order_id") @db.Char(36)
  ticketTypeId String                 @map("ticket_type_id") @db.Char(36)
  quantity     Int
  status       StockReservationStatus @default(ACTIVE)
  expiresAt    DateTime               @map("expires_at")
  releasedAt   DateTime?              @map("released_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType             @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  @@unique([orderId, ticketTypeId])
  @@index([ticketTypeId, status, expiresAt])
  @@index([orderId, status])
  @@map("stock_reservations")
}

model Payment {
  id                   String                @id @default(uuid()) @db.Char(36)
  orderId              String                @map("order_id") @db.Char(36)
  provider             String                @db.VarChar(64)
  transactionReference String                @unique @map("transaction_reference") @db.VarChar(128)
  providerPaymentId    String?               @unique @map("provider_payment_id") @db.VarChar(128)
  idempotencyKey       String?               @unique @map("idempotency_key") @db.VarChar(128)
  amount               Int
  currency             String                @default("XOF") @db.VarChar(8)
  status               PaymentStatus         @default(INITIATED)
  paymentUrl           String?               @map("payment_url") @db.VarChar(512)
  providerStatus       String?               @map("provider_status") @db.VarChar(64)
  failureReason        String?               @map("failure_reason") @db.VarChar(255)
  callbackPayload      Json?                 @map("callback_payload")
  verifiedAt           DateTime?             @map("verified_at")
  paidAt               DateTime?             @map("paid_at")
  attemptCount         Int                   @default(0) @map("attempt_count")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  order                Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  webhookEvents        PaymentWebhookEvent[]

  @@index([orderId, status])
  @@index([provider, status])
  @@map("payments")
}

model PaymentWebhookEvent {
  id               String    @id @default(uuid()) @db.Char(36)
  provider         String    @db.VarChar(64)
  eventReference   String?   @map("event_reference") @db.VarChar(128)
  signatureValid   Boolean   @default(false) @map("signature_valid")
  processingStatus String    @default("PENDING") @map("processing_status") @db.VarChar(32)
  payload          Json
  errorMessage     String?   @map("error_message") @db.VarChar(255)
  processedAt      DateTime? @map("processed_at")
  paymentId        String?   @map("payment_id") @db.Char(36)
  orderId          String?   @map("order_id") @db.Char(36)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  payment          Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  order            Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([provider, eventReference])
  @@index([processingStatus, createdAt])
  @@index([paymentId])
  @@index([orderId])
  @@map("payment_webhook_events")
}

model Ticket {
  id                   String         @id @default(uuid()) @db.Char(36)
  orderId              String         @map("order_id") @db.Char(36)
  orderItemId          String         @map("order_item_id") @db.Char(36)
  eventId              String         @map("event_id") @db.Char(36)
  ticketTypeId         String         @map("ticket_type_id") @db.Char(36)
  ticketCode           String         @unique @map("ticket_code") @db.VarChar(64)
  qrToken              String         @unique @map("qr_token") @db.VarChar(128)
  participantFirstName String?        @map("participant_first_name") @db.VarChar(100)
  participantLastName  String?        @map("participant_last_name") @db.VarChar(100)
  participantEmail     String?        @map("participant_email") @db.VarChar(191)
  participantPhone     String?        @map("participant_phone") @db.VarChar(32)
  status               TicketStatus   @default(GENERATED)
  checkedInAt          DateTime?      @map("checked_in_at")
  cancelledAt          DateTime?      @map("cancelled_at")
  metadata             Json?
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  order                Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem            OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  event                Event          @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticketType           TicketType     @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  scans                TicketScan[]
  raffleEntry          RaffleTicket?
  notifications        Notification[]

  @@index([eventId, status])
  @@index([ticketTypeId, status])
  @@map("tickets")
}

model TicketScan {
  id            String     @id @default(uuid()) @db.Char(36)
  ticketId      String     @map("ticket_id") @db.Char(36)
  scannedById   String     @map("scanned_by_id") @db.Char(36)
  scanResult    ScanResult @map("scan_result")
  scannerDevice String?    @map("scanner_device") @db.VarChar(128)
  scannerIp     String?    @map("scanner_ip") @db.VarChar(64)
  payload       Json?
  scannedAt     DateTime   @default(now()) @map("scanned_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  ticket        Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  scannedBy     User       @relation("ScannerScans", fields: [scannedById], references: [id], onDelete: Restrict)

  @@index([ticketId, scannedAt])
  @@index([scannedById, scannedAt])
  @@map("ticket_scans")
}

model RaffleTicket {
  id           String             @id @default(uuid()) @db.Char(36)
  orderId      String             @map("order_id") @db.Char(36)
  ticketId     String?            @unique @map("ticket_id") @db.Char(36)
  serialNumber String             @unique @map("serial_number") @db.VarChar(64)
  status       RaffleTicketStatus @default(ASSIGNED)
  assignedTo   String?            @map("assigned_to") @db.VarChar(191)
  prizeLabel   String?            @map("prize_label") @db.VarChar(191)
  drawnAt      DateTime?          @map("drawn_at")
  metadata     Json?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticket       Ticket?            @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([status, drawnAt])
  @@map("raffle_tickets")
}

model Notification {
  id                String              @id @default(uuid()) @db.Char(36)
  orderId           String?             @map("order_id") @db.Char(36)
  ticketId          String?             @map("ticket_id") @db.Char(36)
  channel           NotificationChannel
  recipient         String              @db.VarChar(191)
  templateKey       String              @map("template_key") @db.VarChar(100)
  status            NotificationStatus  @default(PENDING)
  providerMessageId String?             @map("provider_message_id") @db.VarChar(128)
  lastError         String?             @map("last_error") @db.VarChar(255)
  payload           Json?
  sentAt            DateTime?           @map("sent_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  order             Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  ticket            Ticket?             @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([status, channel])
  @@index([orderId])
  @@index([ticketId])
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Char(36)
  actorUserId String?  @map("actor_user_id") @db.Char(36)
  action      String   @db.VarChar(100)
  entityType  String   @map("entity_type") @db.VarChar(64)
  entityId    String   @map("entity_id") @db.VarChar(128)
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent") @db.VarChar(255)
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
