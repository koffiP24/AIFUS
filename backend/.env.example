# Backend environment variables
DATABASE_URL="mysql://root:@localhost:3306/aifus_festivites"
JWT_SECRET=change-this-secret-in-production
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FRONTEND_URL=https://aifus.vercel.app
FRONTEND_URLS=https://aifus.vercel.app
V2_ACCESS_TOKEN_EXPIRES_IN=15m
V2_REFRESH_TOKEN_TTL_DAYS=30
ORDER_RESERVATION_TTL_MINUTES=10
PAYMENT_WEBHOOK_SECRET=change-this-payment-secret
FEDAPAY_SECRET_KEY=
FEDAPAY_ENV=sandbox
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_RETURN_URL=https://aifus.vercel.app/payment-return
# Compat legacy: still supported, but prefer FEDAPAY_RETURN_URL
FEDAPAY_CALLBACK_URL=https://aifus.vercel.app/payment-return
# URL to configure in the FedaPay dashboard webhook section.
# It must be a public HTTPS backend endpoint, for example:
# https://your-public-api.example.com/api/v2/payments/webhook
FEDAPAY_WEBHOOK_URL=https://aifus.onrender.com/api/v2/payments/webhook
FEDAPAY_PHONE_COUNTRY=ci
QR_SIGNING_SECRET=change-this-qr-secret
V2_ADMIN_EMAIL=admin@example.com
V2_ADMIN_PASSWORD=change-me
V2_ADMIN_FIRST_NAME=Admin
V2_ADMIN_LAST_NAME=AIFUS
