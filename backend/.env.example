# Backend environment variables
DATABASE_URL="mysql://root:@localhost:3306/aifus_festivites"
JWT_SECRET=change-this-secret-in-production
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FRONTEND_URL=http://localhost:5173
V2_ACCESS_TOKEN_EXPIRES_IN=15m
V2_REFRESH_TOKEN_TTL_DAYS=30
ORDER_RESERVATION_TTL_MINUTES=10
PAYMENT_WEBHOOK_SECRET=change-this-payment-secret
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_CHANNELS=ALL
CINETPAY_LANG=fr
CINETPAY_COUNTRY_CODE=CI
# CinetPay requires public URLs. Do not use localhost here.
# If omitted, the project derives:
# - return:  FRONTEND_URL + /api/v2/payments/return
# - notify:  FRONTEND_URL + /api/v2/payments/webhook
CINETPAY_RETURN_URL=
CINETPAY_NOTIFY_URL=
CINETPAY_WEBHOOK_URL=
QR_SIGNING_SECRET=change-this-qr-secret
V2_ADMIN_EMAIL=admin@example.com
V2_ADMIN_PASSWORD=change-me
V2_ADMIN_FIRST_NAME=Admin
V2_ADMIN_LAST_NAME=AIFUS
